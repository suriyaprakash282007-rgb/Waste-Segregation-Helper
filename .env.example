# Environment Variables — Next.js App
# Copy this file to .env.local and fill in your values

# ─── AWS Credentials ──────────────────────────────────────────────────────────
NEXT_PUBLIC_USE_DEMO_MODE=true

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── S3 Storage ───────────────────────────────────────────────────────────────
AWS_S3_BUCKET_NAME=

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
AWS_DYNAMODB_TABLE=WasteClassifications

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=WasteSense AI
NODE_ENV=development
